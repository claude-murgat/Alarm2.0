FROM postgres:16-alpine

RUN apk add --no-cache python3 py3-pip py3-psycopg2 py3-yaml curl
RUN pip3 install --break-system-packages patroni[etcd3]

COPY patroni/patroni.yml /etc/patroni/patroni.yml
COPY patroni/post_bootstrap.sh /etc/patroni/post_bootstrap.sh
RUN chmod +x /etc/patroni/post_bootstrap.sh

USER postgres
EXPOSE 5432 8008
CMD ["patroni", "/etc/patroni/patroni.yml"]
