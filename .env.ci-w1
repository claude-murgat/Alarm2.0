# Worker 1 du tier 3 e2e CI. Ports decales pour ne pas conflicter avec
# .env.dev (8000) ni .env.ci-w2 (28xxx).
NODE_NAME=ci-w1
BACKEND_PORT=18000
PG_PORT=15432
PATRONI_PORT=18008
ETCD_CLIENT_PORT=12379
ETCD_PEER_PORT=12380
ETCD_HOSTS=host.docker.internal:12379
ETCD_INITIAL_CLUSTER=ci-w1=http://host.docker.internal:12380
PEER_TEST_URLS=
MAILHOG_SMTP_PORT=11025
MAILHOG_WEB_PORT=18025
