# PROD cross-machine — onsite-1 (172.16.1.121, WG 10.99.0.2)
# Cf. docs/PROVISIONING_ONSITE.md §22bis (option D : variabilisation docker-compose).
#
# Differences vs .env.node1 (CI mono-host) :
# - ADVERTISE_HOST : IP Wireguard de cette machine (annoncee aux peers)
# - Ports etcd uniformes 2379/2380 (chaque machine n'a qu'1 etcd)
# - ETCD_HOSTS / ETCD_INITIAL_CLUSTER : les 3 IPs WG du mesh
# - PEER_TEST_URLS : les 2 autres backends via WG
# - Mailhog : desactive (en prod, SMTP relai reel)

NODE_NAME=node1
ADVERTISE_HOST=10.99.0.2

BACKEND_PORT=8000
PG_PORT=5432
PATRONI_PORT=8008
ETCD_CLIENT_PORT=2379
ETCD_PEER_PORT=2380

ETCD_HOSTS=10.99.0.1:2379,10.99.0.2:2379,10.99.0.3:2379
ETCD_INITIAL_CLUSTER=node1=http://10.99.0.2:2380,node2=http://10.99.0.3:2380,node3=http://10.99.0.1:2380

PEER_TEST_URLS=http://10.99.0.3:8000,http://10.99.0.1:8000

MAILHOG_SMTP_PORT=0
MAILHOG_WEB_PORT=0

# Images Docker pullees depuis GHCR (cf docs/CD_DESIGN.md §1 + PR 1 ci/cd-build-ghcr).
# IMAGE_TAG=stable -> pointe sur la promo manuelle courante. Le timer systemd
# (PR 3) pull ce tag toutes les 5 min et compare le digest local.
REGISTRY=ghcr.io/claude-murgat
IMAGE_TAG=stable
