<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/alarmRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#B71C1C">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- ==================== BARRE HAUTE ==================== -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#99000000"
            android:padding="12dp">

            <TextView
                android:id="@+id/alarmIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#x26A0;&#xFE0F;"
                android:textSize="24sp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ALARME CRITIQUE"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/alarmId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#0"
                android:textSize="12sp"
                android:textColor="#FFCDD2" />
        </LinearLayout>

        <!-- ==================== CONTENU CENTRAL ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <TextView
                android:id="@+id/alarmTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Titre de l'alarme"
                android:textSize="28sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textAlignment="center"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/alarmMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description de l'alarme"
                android:textSize="16sp"
                android:textColor="#FFEBEE"
                android:textAlignment="center"
                android:layout_marginBottom="24dp" />

            <!-- Zone post-acquittement -->
            <LinearLayout
                android:id="@+id/ackConfirmation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <com.alarm.critical.view.ArcTimerView
                    android:id="@+id/ackArcTimer"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/ackStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Acquittee"
                    android:textSize="20sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/backToDashboard"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:text="Retour au dashboard"
                    android:backgroundTint="#FFFFFF"
                    android:textColor="#1a1a2e"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ==================== BOUTON ACK EN BAS ==================== -->
        <LinearLayout
            android:id="@+id/bottomSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:background="#40000000">

            <Button
                android:id="@+id/ackButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="ACQUITTER L'ALARME"
                android:contentDescription="ACKNOWLEDGE_ALARM"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/ackHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Suspension de 30 minutes apres acquittement"
                android:textSize="11sp"
                android:textColor="#FFCDD2"
                android:layout_marginTop="8dp" />
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
