<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#B71C1C">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="&#x26A0;&#xFE0F;"
        android:textSize="72sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ALARME CRITIQUE"
        android:textSize="32sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/alarmSeverity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GRAVITÉ : CRITIQUE"
        android:textSize="14sp"
        android:textColor="#FFCDD2"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/alarmId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Alarme #0"
        android:textSize="14sp"
        android:textColor="#FFCDD2"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/alarmTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Titre de l'alarme"
        android:textSize="24sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/alarmMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Description de l'alarme"
        android:textSize="16sp"
        android:textColor="#FFEBEE"
        android:textAlignment="center"
        android:layout_marginBottom="48dp" />

    <Button
        android:id="@+id/ackButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ACQUITTER L'ALARME"
        android:contentDescription="ACKNOWLEDGE_ALARM"
        android:padding="20dp"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="L'acquittement suspendra cette alarme pendant 30 minutes"
        android:textSize="12sp"
        android:textColor="#FFCDD2"
        android:layout_marginTop="12dp" />

    <TextView
        android:id="@+id/ackStatusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:visibility="gone"
        android:layout_marginTop="24dp" />

    <TextView
        android:id="@+id/ackRemainingTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="16sp"
        android:textColor="#FFCDD2"
        android:visibility="gone"
        android:layout_marginTop="8dp" />
</LinearLayout>
