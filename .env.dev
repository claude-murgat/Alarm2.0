NODE_NAME=node1
BACKEND_PORT=8000
PG_PORT=5432
PATRONI_PORT=8008
ETCD_CLIENT_PORT=2379
ETCD_PEER_PORT=2380
ETCD_HOSTS=host.docker.internal:2379
ETCD_INITIAL_CLUSTER=node1=http://host.docker.internal:2380
PEER_TEST_URLS=
MAILHOG_SMTP_PORT=1025
MAILHOG_WEB_PORT=8025
# SECRET_KEY CI/dev : valeur publique, distincte du default de auth.py
# (qui se finit par "-change-in-prod") → /health voit secret_key_default=false.
# La vraie SECRET_KEY prod vit dans .env.prod.secrets (gitignored), pas ici.
SECRET_KEY=ci-dev-key-public-not-secret-2026

# INV-076 : tests E2E utilisent /test/advance-clock + /test/reset-clock
ENABLE_TEST_ENDPOINTS=true
