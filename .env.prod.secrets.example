# PROD secrets — TEMPLATE. NE JAMAIS commiter le vrai .env.prod.secrets.
#
# Procedure de deploiement (a faire UNE fois par machine prod) :
#   1. Copier ce fichier en .env.prod.secrets dans le meme dossier (/opt/alarm) :
#        cp .env.prod.secrets.example .env.prod.secrets
#   2. Remplacer les valeurs <PLACEHOLDER> par les vraies valeurs (cf
#      docs/PROVISIONING_ONSITE.md §22quater pour la procedure de generation +
#      stockage Bitwarden).
#   3. Restreindre les permissions :
#        chmod 600 .env.prod.secrets
#        chown alarm:alarm .env.prod.secrets
#   4. Le wrapper scripts/start-prod-node.sh sourcera ce fichier au bring-up.
#
# Cf .gitignore : .env.prod.secrets est gitignored, mais .env.prod.secrets.example
# (ce fichier) reste committe comme reference / template.

# SECRET_KEY : signe les JWT (auth.py + create_access_token). 256 bits hex.
# Generation : openssl rand -hex 32
# IMPORTANT : si compromise → forge de tokens admin a distance via /api/auth/login.
#             Rotation invalide TOUS les tokens existants (force re-login).
SECRET_KEY=<RUN: openssl rand -hex 32>

# SMTP relay : credentials Gmail (App Password 16 chars, sans espaces).
# Procedure de generation : https://myaccount.google.com/apppasswords
#  - prerequis : validation 2FA active sur le compte Google
#  - generer un App Password (Autre → "Alarm backend") et copier les 16 chars
# Cf docs/PROVISIONING_ONSITE.md §22quater pour la procedure complete + rotation.
#
# - Si HOST = smtp.gmail.com (cf .env.prod.node3) : USER + PASS obligatoires
#   (STARTTLS + AUTH appliques par email_service automatiquement).
# - Si USER/PASS absents : email_service tente un envoi anonyme (compat MailHog dev).
# - Si HOST vide : email_service skip silencieusement (pas de blocage event loop).
SMTP_USER=<adresse-pro-complete@example.com>
SMTP_PASS=<App-Password-Google-16-chars-sans-espaces>

# A venir (placeholder pour les rotations futures de PG passwords / FCM) :
# DATABASE_PASSWORD=<a definir>
# POSTGRES_SUPERUSER_PASSWORD=<a definir>
# REPLICATION_PASSWORD=<a definir>
# FCM_SERVICE_ACCOUNT_PATH=/opt/alarm/secrets/firebase-service-account.json
