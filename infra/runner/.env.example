# Template pour infra/runner/.env (NON commite — voir .gitignore).
# Copier en .env et remplir les valeurs depuis la GitHub App alarm-murgat-bot.

# Repo cible
GH_OWNER=claude-murgat
GH_REPO=Alarm2.0

# GitHub App (Settings → Developer settings → GitHub Apps → alarm-murgat-bot)
APP_ID=000000
# APP_LOGIN = compte ou est INSTALLEE l'App (= proprietaire du repo, pas le nom de l'App).
APP_LOGIN=claude-murgat

# La cle privee .pem doit etre placee a cote de ce fichier sous le nom :
#   alarm-bot.private-key.pem
# Elle est bind-mount automatiquement par docker-compose.runner.yml.
