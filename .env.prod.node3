# PROD cross-machine — NODE3 cloud OVH (51.210.105.102, WG 10.99.0.1)
# Cf. docs/PROVISIONING_ONSITE.md §22bis (option D : variabilisation docker-compose).

NODE_NAME=node3
ADVERTISE_HOST=10.99.0.1

BACKEND_PORT=8000
PG_PORT=5432
PATRONI_PORT=8008
ETCD_CLIENT_PORT=2379
ETCD_PEER_PORT=2380

ETCD_HOSTS=10.99.0.1:2379,10.99.0.2:2379,10.99.0.3:2379
ETCD_INITIAL_CLUSTER=node1=http://10.99.0.2:2380,node2=http://10.99.0.3:2380,node3=http://10.99.0.1:2380

PEER_TEST_URLS=http://10.99.0.2:8000,http://10.99.0.3:8000

# INV-043 (révisé) : node3 est le SEUL nœud joignable par les téléphones
# externes/mobile (les onsite sont sur LAN privé 172.16.x). Quand node3 est un
# replica Patroni, il forwarde le heartbeat au leader via WG au lieu de renvoyer
# 503 — sinon le tél d'astreinte en 4G ne peut jamais heartbeat et croit le
# serveur injoignable alors que le cluster est sain. À NE PAS activer sur
# node1/node2 (onsite) : ils gardent le 503 pour que l'app rotate sur le LAN.
HEARTBEAT_PROXY_ON_REPLICA=true

MAILHOG_SMTP_PORT=0
MAILHOG_WEB_PORT=0

# SMTP relay Gmail (cf issue #105 + docs/PROVISIONING_ONSITE.md §22quater).
# HOST/PORT/FROM publics ici ; USER/PASS sensibles dans .env.prod.secrets (gitignored).
# Si SMTP_USER+SMTP_PASS absents (cas dev/CI), email_service skip STARTTLS+login
# et tente un envoi anonyme (compatible MailHog).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=direction_technique@charlesmurgat.com
SMTP_TIMEOUT=10

# Images Docker pullees depuis GHCR (cf docs/CD_DESIGN.md §1 + PR 1 ci/cd-build-ghcr).
REGISTRY=ghcr.io/claude-murgat
IMAGE_TAG=stable
