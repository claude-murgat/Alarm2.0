# .env dedie au tier4-failback CI workflow.
#
# Pourquoi un .env distinct de .env.node1/2/3 :
#   .env.node{1,2,3} sont concus pour un cluster Patroni 3-node (3 etcd peers
#   + 3 patroni members). Le tier4-failback lance UN seul etcd via
#   docker-compose.yml (le compose vps1) avec ETCD_INITIAL_CLUSTER pointant
#   vers 3 peers - 2 absents - donc le quorum n'est jamais atteint et le
#   healthcheck etcd timeout (chasse de leader infinie). Patroni jamais ready,
#   backend depends_on Patroni, donc backend jamais ready -> Boot cluster fail.
#
# Solution : cluster etcd mono-node (taille 1 = quorum trivial). Single point
# of failure cote etcd, mais OK pour le tier4 dont le but n'est PAS de tester
# la HA d'etcd mais la rotation client (ApiClient.kt) entre 2 backends quand
# l'un d'eux tombe.
#
# vps2 (docker-compose.vps2.yml) n'utilise PAS Patroni / etcd : c'est un
# PostgreSQL standby + backend simple. Donc 0 modif requise pour vps2.

NODE_NAME=node1
BACKEND_PORT=8000
PG_PORT=5432
PATRONI_PORT=8008
ETCD_CLIENT_PORT=2379
ETCD_PEER_PORT=2380

# Mono-node etcd : un seul endpoint, un seul peer dans le cluster initial.
ETCD_HOSTS=host.docker.internal:2379
ETCD_INITIAL_CLUSTER=node1=http://host.docker.internal:2380

# Un seul peer backend visible : le vps2 sur :8001.
PEER_TEST_URLS=http://host.docker.internal:8001

MAILHOG_SMTP_PORT=1025
MAILHOG_WEB_PORT=8025
