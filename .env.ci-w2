# Worker 2 du tier 3 e2e CI. Ports decales pour ne pas conflicter avec
# .env.dev (8000) ni .env.ci-w1 (18xxx).
NODE_NAME=ci-w2
BACKEND_PORT=28000
PG_PORT=25432
PATRONI_PORT=28008
ETCD_CLIENT_PORT=22379
ETCD_PEER_PORT=22380
ETCD_HOSTS=host.docker.internal:22379
ETCD_INITIAL_CLUSTER=ci-w2=http://host.docker.internal:22380
PEER_TEST_URLS=
MAILHOG_SMTP_PORT=21025
MAILHOG_WEB_PORT=28025
# CORS : test_improvements::test_cors_allows_legitimate_origin verifie qu'une
# origine = host:port mappe est acceptee. En CI le test vient de host.docker.internal:28000.
ALLOWED_ORIGINS=http://localhost:28000,http://host.docker.internal:28000
