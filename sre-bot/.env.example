# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Slack — App créée sur api.slack.com/apps avec Socket Mode activé
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Sysadmin à escalader si le bot est bloqué (Slack user ID, pas username)
ESCALATE_SLACK_USER_ID=U02U94G6LMP

# Modèle Claude
CLAUDE_MODEL=claude-opus-4-7

# Audit log (sera créé automatiquement si absent)
AUDIT_LOG_PATH=./audit.log

# Auto-close des sessions inactives (en secondes)
AUTOCLOSE_AFTER_S=1800           # 30 min sans message user → archive
AUTOCLOSE_SCAN_INTERVAL_S=300    # scan toutes les 5 min

# Chemin des clés SSH pour les nodes prod
SSH_KEY_NODE3=/home/murgat/.ssh/alarm_node3
SSH_KEY_ONSITE_1=/home/murgat/.ssh/alarm_onsite_1
SSH_KEY_ONSITE_2=/home/murgat/.ssh/alarm_onsite_2
